{
  "mcpServers": {
    "uptime-kuma-agent": {
      "command": "uptime-kuma-agent",
      "args": [
        "--transport",
        "stdio"
      ],
      "env": {
        "UPTIME_KUMA_URL": "${UPTIME_KUMA_URL}",
        "UPTIME_KUMA_TOKEN": "${UPTIME_KUMA_TOKEN}",
        "MONITORSTOOL": "True",
        "STATUSTOOL": "True"
      }
    }
  }
}
