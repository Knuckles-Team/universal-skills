{
    "mcpServers": {
        "tunnel-manager-mcp": {
            "command": "tunnel-manager-mcp",
            "args": [
                "--transport",
                "stdio"
            ],
            "env": {
                "TUNNEL_IDENTITY_FILE": "${TUNNEL_IDENTITY_FILE}",
                "HOST_MANAGEMENTTOOL": "${ HOST_MANAGEMENTTOOL:-True }",
                "MISCTOOL": "${ MISCTOOL:-True }",
                "REMOTE_ACCESSTOOL": "${ REMOTE_ACCESSTOOL:-True }"
            }
        }
    }
}
