{
    "mcpServers": {
        "leanix-agent": {
            "command": "leanix-agent-mcp",
            "args": [
                "--transport",
                "stdio"
            ],
            "env": {
                "LEANIX_WORKSPACE": "${LEANIX_WORKSPACE}",
                "LEANIX_API_TOKEN": "${LEANIX_API_TOKEN}",
                "FACTSHEETSTOOL": "${FACTSHEETSTOOL:-True}",
                "GRAPHQLTOOL": "${GRAPHQLTOOL:-True}"
            }
        }
    }
}
