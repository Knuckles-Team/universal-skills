{
  "mcpServers": {
    "nextcloud-agent": {
      "command": "nextcloud-mcp",
      "args": [
        "--transport",
        "stdio"
      ],
      "env": {
        "NEXTCLOUD_URL": "${NEXTCLOUD_URL}",
        "NEXTCLOUD_USERNAME": "${NEXTCLOUD_USERNAME}",
        "NEXTCLOUD_PASSWORD": "${NEXTCLOUD_PASSWORD}",
        "CALENDARTOOL": "True",
        "CONTACTSTOOL": "True",
        "FILESTOOL": "True",
        "MISCTOOL": "True",
        "SHARINGTOOL": "True",
        "USERTOOL": "True"
      }
    }
  }
}
