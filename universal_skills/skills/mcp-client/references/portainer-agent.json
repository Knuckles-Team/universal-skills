{
    "mcpServers": {
        "portainer-agent": {
            "command": "portainer-mcp",
            "args": [
                "--transport",
                "stdio"
            ],
            "env": {
                "PORTAINER_URL": "${PORTAINER_URL}",
                "PORTAINER_TOKEN": "${PORTAINER_TOKEN}",
                "AUTHTOOL": "True",
                "ENVIRONMENTTOOL": "True",
                "DOCKERTOOL": "True",
                "STACKTOOL": "True",
                "KUBERNETESTOOL": "True",
                "EDGETOOL": "True",
                "TEMPLATETOOL": "True",
                "USERTOOL": "True",
                "REGISTRYTOOL": "True",
                "SYSTEMTOOL": "True"
            }
        }
    }
}
