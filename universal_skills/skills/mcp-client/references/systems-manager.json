{
  "mcpServers": {
    "systems-manager": {
      "command": "systems-manager-mcp",
      "args": [
        "--transport",
        "stdio"
      ],
      "env": {
        "CRONTOOL": "True",
        "DISKTOOL": "True",
        "FILESYSTEMTOOL": "True",
        "FIREWALL_MANAGEMENTTOOL": "True",
        "LOGTOOL": "True",
        "MISCTOOL": "True",
        "NETWORKTOOL": "True",
        "NODEJSTOOL": "True",
        "PROCESSTOOL": "True",
        "PYTHONTOOL": "True",
        "SERVICETOOL": "True",
        "SHELLTOOL": "True",
        "SSH_MANAGEMENTTOOL": "True",
        "SYSTEMTOOL": "True",
        "SYSTEM_MANAGEMENTTOOL": "True",
        "TEXT_EDITORTOOL": "True",
        "USERTOOL": "True"
      }
    }
  }
}
